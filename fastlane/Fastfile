# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:android)

platform :android do
  desc "Upload AAB to Google Play"
  lane :playstore do |options|
    # skip_metadata:"true" uploads the binary ONLY and leaves the live store listing (metadata,
    # images, screenshots, changelogs) untouched. Default (false) uploads the full listing too.
    skip_meta = options[:skip_metadata].to_s == 'true'
    upload_params = {
        aab: options[:aab],
        json_key_data: ENV['GOOGLE_PLAY_API_KEY'],
        track: options[:track] || 'alpha',
        version_name: options[:version_name],
        version_code: options[:version_code],
        skip_upload_apk: true,
        skip_upload_screenshots: skip_meta,
        skip_upload_images: skip_meta,
        skip_upload_metadata: skip_meta,
        skip_upload_changelogs: skip_meta,
        sync_image_upload: !skip_meta,
        # A staged rollout (fraction < 1, e.g. 0.01 = 1%) must be 'inProgress'; a full release is
        # 'completed'. Passing rollout with 'completed' is rejected by the Play API.
        release_status: (options[:rollout].to_s.empty? || options[:rollout].to_f >= 1.0) ? 'completed' : 'inProgress'
    }

    # Only add rollout if it has a valid value (a fraction between 0 and 1, e.g. 0.01 = 1%)
    if options[:rollout] && !options[:rollout].to_s.empty?
      upload_params[:rollout] = options[:rollout]
    end

    # No rescue on purpose: ANY error from upload_to_play_store must fail the lane (and the CI job)
    # loudly. A previous version swallowed "version code already used" / apkNoUpgradePath as a benign
    # "already exists, just updating the changelog" — but apkNoUpgradePath is a REJECTION (the AAB is
    # not a valid upgrade of what's already live), so the binary never landed while CI reported
    # success. If you genuinely need to refresh only the store listing for an already-published
    # version, use the publish_contents lane, not playstore.
    UI.message("🚀 Uploading AAB with changelog...")
    UI.message("   versionCode=#{options[:version_code]} track=#{upload_params[:track]} rollout=#{upload_params[:rollout] || 'none'}")
    upload_to_play_store(upload_params)
    UI.success("✅ Upload of AAB and changelog succeeded")
  end

  desc "Publish store contents (metadata, images, screenshots) to Google Play - shared across all tracks"
  lane :publish_contents do |options|
    UI.message("🚀 Finding the latest version code on the production track...")

    # Step 1: Fetch all active version codes from the production track
    production_versions = google_play_track_version_codes(
      json_key_data: ENV['GOOGLE_PLAY_API_KEY'],
      track: 'production'
    )

    # Step 2: Find the highest (latest) version code from the array
    latest_version_code = production_versions.max
    
    if latest_version_code.nil?
      UI.user_error!("Could not find any active version on the production track.")
    end

    UI.message("✅ Found latest version code: #{latest_version_code}")
    UI.message("🚀 Publishing store contents (metadata, images, screenshots)...")
    UI.message("   Note: Store contents are shared across all tracks")
    
    supply(
      json_key_data: ENV['GOOGLE_PLAY_API_KEY'],
      version_code: latest_version_code,
      skip_upload_aab: true,
      skip_upload_apk: true,
      skip_upload_screenshots: false,
      skip_upload_images: false,
      skip_upload_metadata: false,
      skip_upload_changelogs: true,
      sync_image_upload: true
    )
    
    UI.success("✅ Store contents published successfully")
  end

  desc "Download universal Play-signed APK"
  lane :download_signed do |options|
    # Ensure version_code provided (Play API requires specifying to fetch generated universal apk)
    unless options[:version_code]
      UI.user_error!("version_code is required. Pass via 'fastlane android download_signed version_code:123'.")
    end
    download_universal_apk_from_google_play(
        json_key_data: ENV['GOOGLE_PLAY_API_KEY'],
        version_code: options[:version_code],
        destination: './fastlane/downloaded.apk'
    )
    UI.success("Downloaded universal APK for version code #{options[:version_code]}")
  end
end
