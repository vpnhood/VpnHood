<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>iOS (Apple Network.framework, iOS 15+) implementation of the VpnHood QUIC abstractions.</Description>
		<TargetFramework>net11.0-ios</TargetFramework>
		<SupportedOSPlatformVersion>15.0</SupportedOSPlatformVersion>
		<RootNamespace>VpnHood.Core.Quic.Ios</RootNamespace>
	</PropertyGroup>

	<PropertyGroup>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<ItemGroup>
		<!-- VpnHood.Core.Toolkit provides SystemSocketFactory and transitively references
		     VpnHood.Core.Quic.Abstractions -->
		<ProjectReference Include="..\VpnHood.Core.Toolkit\VpnHood.Core.Toolkit.csproj" />
	</ItemGroup>

</Project>
