		<TargetFramework>net10.0-android36.1</TargetFramework>
		<SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>
		<RootNamespace>VpnHood.AppLib.Droid.GooglePlay</RootNamespace>
	</PropertyGroup>

	<PropertyGroup>
		<BaseIntermediateOutputPath />
	</PropertyGroup>

	<!--Xamarin.Android.Google.BillingClient 8.0.0 required to prevent conflict Tried: 2025/12/25-->
