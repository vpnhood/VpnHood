<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<IsPackable>false</IsPackable>	<!-- application, not a NuGet package -->
		<Product>VpnHood! CLIENT</Product>
		<Description>VpnHood Windows Client App</Description>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
		<UseWPF>true</UseWPF>
		<UseWindowsForms>False</UseWindowsForms>
		<AssemblyName>VpnHoodClient</AssemblyName>
		<ApplicationIcon>Resources\VpnHood.ico</ApplicationIcon>
		<EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
		<SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
		<ApplicationManifest>Properties/app.manifest</ApplicationManifest>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<RuntimeIdentifiers>win-x64</RuntimeIdentifiers>
    </PropertyGroup>

	<PropertyGroup>
		<AssemblyVersion></AssemblyVersion>
	</PropertyGroup>

	<!-- Optional private app settings (from the external ".user" folder) embedded as resources.
	     Conditional so a fork without them still builds; AppConfigs reads them at startup. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\appsettings.json"
			LogicalName="AppSettings.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\appsettings.json')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\appsettings.$(Configuration).json"
			LogicalName="AppSettings_Environment.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\appsettings.$(Configuration).json')" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Win.Common.WpfSpa\VpnHood.AppLib.Win.Common.WpfSpa.csproj" />
	</ItemGroup>

</Project>
