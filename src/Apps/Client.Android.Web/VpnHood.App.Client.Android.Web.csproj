<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<IsPackable>false</IsPackable>	<!-- application, not a NuGet package -->
		<Description>VpnHood Android Client App</Description>
		<TargetFramework>net10.0-android36.1</TargetFramework>
		<RootNamespace>VpnHood.App.Client.Droid.Web</RootNamespace>
		<OutputType>Exe</OutputType>
		<ApplicationId>com.vpnhood.client.android.web.debug</ApplicationId>
		<SupportedOSPlatformVersion>24.0</SupportedOSPlatformVersion>
		<DebugSymbols>True</DebugSymbols>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Debug'">
		<RuntimeIdentifiers>android-arm64;android-x64</RuntimeIdentifiers>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<!--android-arm is required for some android TVs-->
		<UseCurrentRuntimeIdentifier>false</UseCurrentRuntimeIdentifier>
		<RuntimeIdentifier>android-arm64</RuntimeIdentifier>
		<RuntimeIdentifiers>android-arm64;android-x64;android-arm</RuntimeIdentifiers>
		<PublishTrimmed>True</PublishTrimmed>
		<!-- TEMP-CI-AOT-OFF: AOT disabled to speed up CI release builds while the Android
		     pipeline is being wired up. REVERT to True (grep "TEMP-CI-AOT-OFF") before
		     shipping a production release. -->
		<RunAOTCompilation>False</RunAOTCompilation>
		<!--<AndroidLinkTool>r8</AndroidLinkTool>-->
	</PropertyGroup>

	<PropertyGroup>
		<DebugSymbols>True</DebugSymbols>
	</PropertyGroup>

	<PropertyGroup>
		<BaseIntermediateOutputPath />
	</PropertyGroup>

	<!-- Optional private app settings (from the external ".user" folder) embedded as resources.
	     Conditional so a fork without them still builds; AppConfigs reads them at startup. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\appsettings.json" LogicalName="AppSettings.json" Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\appsettings.json')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\appsettings.$(Configuration).json" LogicalName="AppSettings_Environment.json" Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\appsettings.$(Configuration).json')" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Include="VpnHood.AppLib.Assets.Ip2LocationLite" Version="7.0.740" />
	</ItemGroup>

	<ItemGroup>
		<AndroidResource Update="Resources\xml\locales_config.xml">
			<SubType>Designer</SubType>
			<Generator>MSBuild:UpdateGeneratedFiles</Generator>
		</AndroidResource>
	</ItemGroup>
	
	<ItemGroup>
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Android.Common\VpnHood.AppLib.Android.Common.csproj" />
		<ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
	</ItemGroup>

</Project>