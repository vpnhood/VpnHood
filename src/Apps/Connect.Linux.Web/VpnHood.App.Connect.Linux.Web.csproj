<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<IsPackable>false</IsPackable>	<!-- application, not a NuGet package -->
		<Product>VpnHood! CONNECT</Product>
		<Description>VpnHood Linux Connect App</Description>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<UseWindowsForms>False</UseWindowsForms>
		<AssemblyName>VpnHoodConnect</AssemblyName>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<PublishTrimmed>False</PublishTrimmed>
		<RunAOTCompilation>False</RunAOTCompilation>
	</PropertyGroup>

	<PropertyGroup>
		<StartupObject></StartupObject>
	</PropertyGroup>

	<!-- Optional private app settings (from the external ".user" folder) embedded as resources.
	     Conditional so a fork without them still builds; AppConfigs reads them at startup. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.json" LogicalName="AppSettings.json" Condition="Exists('$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.json')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.$(Configuration).json" LogicalName="AppSettings_Environment.json" Condition="Exists('$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.$(Configuration).json')" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Linux.Common\VpnHood.AppLib.Linux.Common.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="VpnHood.AppLib.Assets.Ip2LocationLite" Version="7.0.740" />
	</ItemGroup>

</Project>
