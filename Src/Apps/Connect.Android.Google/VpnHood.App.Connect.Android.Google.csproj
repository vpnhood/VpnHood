<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>VpnHood Android Client Connect App with Ads and memebership</Description>
		<TargetFramework>net10.0-android36.1</TargetFramework>
		<RootNamespace>VpnHood.App.Connect.Droid.Google</RootNamespace>
		<OutputType>Exe</OutputType>
		<ApplicationId>com.vpnhood.connect.android</ApplicationId>
		<ApplicationVersion>811</ApplicationVersion>
		<ApplicationDisplayVersion>7.9.811</ApplicationDisplayVersion>
		<SupportedOSPlatformVersion>24.0</SupportedOSPlatformVersion>
		<DebugSymbols>True</DebugSymbols>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Debug'">
		<RuntimeIdentifiers>android-arm64;android-x64</RuntimeIdentifiers>
	</PropertyGroup>
	
	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<!--android-arm is required for some android TVs-->
		<UseCurrentRuntimeIdentifier>false</UseCurrentRuntimeIdentifier>
		<RuntimeIdentifier>android-arm64</RuntimeIdentifier>
		<RuntimeIdentifiers>android-arm64;android-x64;android-arm</RuntimeIdentifiers>
		<PublishTrimmed>True</PublishTrimmed>
		<RunAOTCompilation>True</RunAOTCompilation>
		<!--<AndroidLinkTool>r8</AndroidLinkTool> debugging-->
		<PathMap>$(SolutionDir)=.</PathMap>
	</PropertyGroup>

	<PropertyGroup>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IncludeSymbols>True</IncludeSymbols>
		<SymbolPackageFormat>symbols.nupkg</SymbolPackageFormat>
		<LangVersion>latest</LangVersion>
	</PropertyGroup>

	<PropertyGroup>
		<PackageLicenseExpression>LGPL-2.1-only</PackageLicenseExpression>
		<Company>OmegaHood LLC</Company>
		<Copyright>© OmegaHood LLC. All rights reserved.</Copyright>
		<PackageIcon>VpnHood.png</PackageIcon>
		<PackageProjectUrl>https://github.com/vpnhood/vpnhood</PackageProjectUrl>
		<RepositoryUrl>https://github.com/vpnhood/vpnhood</RepositoryUrl>
		<Version>7.9.811</Version>
		<FileVersion>$([System.DateTime]::Now.ToString("yyyy.M.d.HHmm"))</FileVersion>
		<BaseIntermediateOutputPath />
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
	  <AndroidKeyStore>False</AndroidKeyStore>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
	  <AndroidKeyStore>False</AndroidKeyStore>
	</PropertyGroup>

	<!-- Optional private app settings (from the external ".user" folder) embedded as resources.
	     Conditional so a fork without them still builds; AppConfigs reads them at startup. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\google\appsettings.json"
			LogicalName="AppSettings.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodConnect\google\appsettings.json')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\google\appsettings.$(Configuration).json"
			LogicalName="AppSettings_Environment.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodConnect\google\appsettings.$(Configuration).json')" />
	</ItemGroup>

	<ItemGroup>
		<AndroidResource Update="Resources\xml\locales_config.xml">
			<SubType>Designer</SubType>
			<Generator>MSBuild:UpdateGeneratedFiles</Generator>
		</AndroidResource>
	</ItemGroup>

	<PropertyGroup>
		<!--Firebase.Analytics version, and the version the DataStore.Preferences pin below was last verified against.
		    Firebase.Common (pulled in via Firebase.Analytics) is what drags in the stale DataStore.Preferences; when you
		    bump FirebaseAnalyticsVersion the build warns until you re-check the pin and bump DataStorePinVerifiedAgainst
		    to match (see the WarnOnDataStorePinReview target).-->
		<FirebaseAnalyticsVersion>123.2.0</FirebaseAnalyticsVersion>
		<DataStorePinVerifiedAgainst>123.2.0</DataStorePinVerifiedAgainst>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Xamarin.Firebase.Analytics" Version="$(FirebaseAnalyticsVersion)" />
		<PackageReference Include="Xamarin.Firebase.Crashlytics" Version="120.0.6" />
		<!--Align AndroidX DataStore.Preferences with the core DataStore 1.2.1 pulled in by GooglePlayServices.Ads/Firebase.Sessions.
		    Firebase.Common otherwise drags in DataStore.Preferences 1.2.0.2 which caps the core at <1.2.1 (NU1608).
		    REMOVE THIS once Firebase.Common ships DataStore.Preferences >= 1.2.1: delete this line, build, and if NU1608
		    does not return it's no longer needed. Pinned: 2026/06/24-->
		<PackageReference Include="Xamarin.AndroidX.DataStore.Preferences" Version="1.2.1" />
	</ItemGroup>

	<!--Reminder to revisit the DataStore.Preferences pin whenever Firebase.Analytics is upgraded (the stale transitive
	    Preferences arrives via Firebase.Common). Fires until DataStorePinVerifiedAgainst is bumped to match.-->
	<Target Name="WarnOnDataStorePinReview" BeforeTargets="Build"
			Condition="'$(FirebaseAnalyticsVersion)' != '$(DataStorePinVerifiedAgainst)'">
		<Warning Text="Xamarin.Firebase.Analytics was upgraded to $(FirebaseAnalyticsVersion) (DataStore.Preferences pin last verified against $(DataStorePinVerifiedAgainst)). Re-check the Xamarin.AndroidX.DataStore.Preferences pin: remove it, build, and see if NU1608 returns. If not, delete the pin; either way set DataStorePinVerifiedAgainst to $(FirebaseAnalyticsVersion)." />
	</Target>

	<ItemGroup>
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Android.Ads.AdMob\VpnHood.AppLib.Android.Ads.AdMob.csproj" />
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Android.GooglePlay.Core\VpnHood.AppLib.Android.GooglePlay.Core.csproj" />
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Android.GooglePlay\VpnHood.AppLib.Android.GooglePlay.csproj" />
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Android.Common\VpnHood.AppLib.Android.Common.csproj" />
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Store\VpnHood.AppLib.Store.csproj" />
		<ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
	</ItemGroup>

	<ItemGroup>
		<GoogleServicesJson Include="Properties\google-services.json" />
	</ItemGroup>

</Project>