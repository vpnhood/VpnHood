<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net11.0-ios</TargetFramework>
    <RuntimeIdentifier>ios-arm64</RuntimeIdentifier>
    <SupportedOSPlatformVersion>18.0</SupportedOSPlatformVersion>
    <UseMaui>false</UseMaui>
    <NullabilityInfoContextSupport>true</NullabilityInfoContextSupport>
    <RootNamespace>VpnHood.App.Client.Ios</RootNamespace>
    <BundleIdentifier>com.vpnhood.client.ios</BundleIdentifier>
    <CodesignEntitlements>Entitlements.plist</CodesignEntitlements>

    <!-- Automatic signing: Xcode picks the cert/profile for the team (6KKW3MKLR7, OmegaHood LLC). -->
    <AutomaticProvisioning>true</AutomaticProvisioning>
    <CodesignKey>Apple Development</CodesignKey>

  </PropertyGroup>

  <!-- Optional private app settings (from the external ".user" folder, sibling to the solution) embedded as
       resources. Mirrors Client.Android.Web. Conditional so a fork without them still builds; AppConfigs
       reads them at startup via AppConfigsBase.LoadConfig(). Client is bring-your-own-key, so unlike Connect
       there is no embedded default access key. Forward slashes: this builds on macOS. -->
  <ItemGroup>
    <EmbeddedResource Include="$(SolutionDir)/../.user/VpnHoodClient/appsettings.json"
        LogicalName="AppSettings.json"
        Condition="Exists('$(SolutionDir)/../.user/VpnHoodClient/appsettings.json')" />
    <EmbeddedResource Include="$(SolutionDir)/../.user/VpnHoodClient/appsettings.$(Configuration).json"
        LogicalName="AppSettings_Environment.json"
        Condition="Exists('$(SolutionDir)/../.user/VpnHoodClient/appsettings.$(Configuration).json')" />
  </ItemGroup>

  <ItemGroup>
    <!-- App framework + iOS device abstraction. -->
    <ProjectReference Include="..\..\AppLib\VpnHood.AppLib.App\VpnHood.AppLib.App.csproj" />
    <ProjectReference Include="..\..\Core\VpnHood.Core.Client.Devices.Abstractions\VpnHood.Core.Client.Devices.Abstractions.csproj" />
    <!-- Concrete iOS IDevice (IosDevice) + IPC message client live in the core Device.iOS project. -->
    <ProjectReference Include="..\..\Core\VpnHood.Core.Client.Devices.Ios\VpnHood.Core.Client.Devices.Ios.csproj" />
    <!-- iOS shared app code: VpnHoodIosApp bootstrap + the WKWebView SPA host. -->
    <ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Ios.Common\VpnHood.AppLib.Ios.Common.csproj" />
    <!-- Shared client resources: embedded SPA (SpaZipData) + IP-location db + ClientAppResources. -->
    <ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bundle the Network Extension as a PlugIn (.appex) inside the host app. UndefineProperties drops
         the app's global /p:CodesignProvision (the App Store publish passes the *app* profile) when
         building this reference, so the .appex resolves its OWN App Store profile from its csproj
         instead of being signed with the app profile (App-ID mismatch -> codesign failure). -->
    <ProjectReference Include="..\Client.Ios.Extension\VpnHood.App.Client.Ios.Extension.csproj">
      <IsAppExtension>true</IsAppExtension>
      <UndefineProperties>CodesignProvision</UndefineProperties>
    </ProjectReference>
  </ItemGroup>

</Project>
