<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<IsPackable>false</IsPackable>	<!-- application, not a NuGet package -->
		<Description>VpnHood Android Client Connect App with Ads and memebership</Description>
		<TargetFramework>net10.0-android36.1</TargetFramework>
		<RootNamespace>VpnHood.App.Connect.Droid.Web</RootNamespace>
		<OutputType>Exe</OutputType>
		<ApplicationId>com.vpnhood.connect.android.web.debug</ApplicationId>
		<SupportedOSPlatformVersion>24.0</SupportedOSPlatformVersion>
		<DebugSymbols>True</DebugSymbols>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Debug'">
		<RuntimeIdentifiers>android-arm64;android-x64;</RuntimeIdentifiers>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<!--android-arm is required for some android TVs-->
		<UseCurrentRuntimeIdentifier>false</UseCurrentRuntimeIdentifier>
		<RuntimeIdentifier>android-arm64</RuntimeIdentifier>
		<RuntimeIdentifiers>android-arm64;android-x64;android-arm</RuntimeIdentifiers>
		<PublishTrimmed>True</PublishTrimmed>
		<RunAOTCompilation>True</RunAOTCompilation>
		<!--<AndroidLinkTool>r8</AndroidLinkTool>-->
	</PropertyGroup>

	<PropertyGroup>
		<BaseIntermediateOutputPath />
	</PropertyGroup>

	<!-- Optional private app settings (from the external ".user" folder) embedded as resources.
	     Conditional so a fork without them still builds; AppConfigs reads them at startup. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.json"
			LogicalName="AppSettings.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.json')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.$(Configuration).json"
			LogicalName="AppSettings_Environment.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodConnect\appsettings.$(Configuration).json')" />
	</ItemGroup>

	<!-- Default access key, embedded as its own resource so it can be sourced from a GitHub secret.
	     The configuration-specific file wins (Debug embeds access_key_default_web.Debug.txt), otherwise
	     the base access_key_default_web.txt is used. Both are optional: a fork without them falls back to the
	     in-code default in AppConfigs. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\web\access_key_default_web.$(Configuration).txt"
			LogicalName="access_key_default.txt"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodConnect\web\access_key_default_web.$(Configuration).txt')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodConnect\web\access_key_default_web.txt"
			LogicalName="access_key_default.txt"
			Condition="!Exists('$(SolutionDir)\..\.user\VpnHoodConnect\web\access_key_default_web.$(Configuration).txt') And Exists('$(SolutionDir)\..\.user\VpnHoodConnect\web\access_key_default_web.txt')" />
	</ItemGroup>

	<ItemGroup>
		<AndroidResource Update="Resources\xml\locales_config.xml">
			<SubType>Designer</SubType>
			<Generator>MSBuild:UpdateGeneratedFiles</Generator>
		</AndroidResource>
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Android.Common\VpnHood.AppLib.Android.Common.csproj" />
		<ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
		<PackageReference Include="AppsFlyerXamarinBindingAndroid" Version="6.17.5" />
	</ItemGroup>

</Project>