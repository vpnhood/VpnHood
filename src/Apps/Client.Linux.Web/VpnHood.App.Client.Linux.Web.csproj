<Project Sdk="Microsoft.NET.Sdk;Microsoft.NET.Sdk.Publish">
	<PropertyGroup>
		<IsPackable>false</IsPackable>	<!-- application, not a NuGet package -->
		<Product>VpnHood! CLIENT</Product>
		<Description>VpnHood Linux Client App</Description>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<AssemblyName>VpnHoodClient</AssemblyName>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<PublishTrimmed>False</PublishTrimmed>
		<RunAOTCompilation>False</RunAOTCompilation>
		<!--<PathMap>$(SolutionDir)=.</PathMap>-->
	</PropertyGroup>

	<PropertyGroup>
		<AssemblyVersion></AssemblyVersion>
	</PropertyGroup>

	<!-- Optional private app settings (from the external ".user" folder) embedded as resources.
	     Conditional so a fork without them still builds; AppConfigs reads them at startup. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\appsettings.json"
			LogicalName="AppSettings.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\appsettings.json')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\appsettings.$(Configuration).json"
			LogicalName="AppSettings_Environment.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\appsettings.$(Configuration).json')" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Linux.Common\VpnHood.AppLib.Linux.Common.csproj" />
		<ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
	</ItemGroup>

</Project>
