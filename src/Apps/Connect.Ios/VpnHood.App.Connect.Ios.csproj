<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net11.0-ios</TargetFramework>
    <RuntimeIdentifier>ios-arm64</RuntimeIdentifier>
    <SupportedOSPlatformVersion>18.0</SupportedOSPlatformVersion>
    <UseMaui>false</UseMaui>
    <NullabilityInfoContextSupport>true</NullabilityInfoContextSupport>
    <RootNamespace>VpnHood.App.Connect.Ios</RootNamespace>
    <BundleIdentifier>com.vpnhood.connect.ios</BundleIdentifier>
    <CodesignEntitlements>Entitlements.plist</CodesignEntitlements>

    <!-- Automatic signing: Xcode picks the cert/profile for the team (6KKW3MKLR7, OmegaHood LLC). -->
    <AutomaticProvisioning>true</AutomaticProvisioning>
    <CodesignKey>Apple Development</CodesignKey>

    <!-- Build against a newer Xcode than the pinned net11 preview.5 workload (Xcode 26.5). The SDK only
         validates Xcode major.minor and 26.5 -> 26.6 is forward-compatible. The target below warns
         (VPNHOOD0001) when this override can be removed. -->
    <ValidateXcodeVersion>false</ValidateXcodeVersion>
  </PropertyGroup>

  <!-- Optional private app settings (from the external ".user" folder, sibling to the solution) embedded as
       resources. Mirrors Connect.Android.Web. Conditional so a fork without them still builds; AppConfigs
       reads them at startup via AppConfigsBase.LoadConfig(). Forward slashes: this builds on macOS. -->
  <ItemGroup>
    <EmbeddedResource Include="$(SolutionDir)/../.user/VpnHoodConnect/appsettings.json"
        LogicalName="AppSettings.json"
        Condition="Exists('$(SolutionDir)/../.user/VpnHoodConnect/appsettings.json')" />
    <EmbeddedResource Include="$(SolutionDir)/../.user/VpnHoodConnect/appsettings.$(Configuration).json"
        LogicalName="AppSettings_Environment.json"
        Condition="Exists('$(SolutionDir)/../.user/VpnHoodConnect/appsettings.$(Configuration).json')" />
  </ItemGroup>

  <!-- Default access key, embedded as its own resource so it can be sourced from a GitHub secret. The
       configuration-specific file wins (Debug embeds access_key_default_web.Debug.txt), otherwise the base
       access_key_default_web.txt is used. Both optional: a fork without them falls back to the in-code
       default in AppConfigs (null -> the UI prompts for a key). -->
  <ItemGroup>
    <EmbeddedResource Include="$(SolutionDir)/../.user/VpnHoodConnect/web/access_key_default_web.$(Configuration).txt"
        LogicalName="access_key_default.txt"
        Condition="Exists('$(SolutionDir)/../.user/VpnHoodConnect/web/access_key_default_web.$(Configuration).txt')" />
    <EmbeddedResource Include="$(SolutionDir)/../.user/VpnHoodConnect/web/access_key_default_web.txt"
        LogicalName="access_key_default.txt"
        Condition="!Exists('$(SolutionDir)/../.user/VpnHoodConnect/web/access_key_default_web.$(Configuration).txt') And Exists('$(SolutionDir)/../.user/VpnHoodConnect/web/access_key_default_web.txt')" />
  </ItemGroup>

  <ItemGroup>
    <!-- App framework + iOS device abstraction. -->
    <ProjectReference Include="..\..\AppLib\VpnHood.AppLib.App\VpnHood.AppLib.App.csproj" />
    <ProjectReference Include="..\..\Core\VpnHood.Core.Client.Devices.Abstractions\VpnHood.Core.Client.Devices.Abstractions.csproj" />
    <!-- Concrete iOS IDevice (IosDevice) + IPC message client live in the core Device.iOS project. -->
    <ProjectReference Include="..\..\Core\VpnHood.Core.Client.Devices.Ios\VpnHood.Core.Client.Devices.Ios.csproj" />
    <!-- iOS shared app code: VpnHoodIosApp bootstrap + the WKWebView SPA host. -->
    <ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Ios.Common\VpnHood.AppLib.Ios.Common.csproj" />
    <!-- Shared client resources: embedded SPA (SpaZipData) + IP-location db + ConnectAppResources. -->
    <ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Bundle the Network Extension as a PlugIn (.appex) inside the host app. UndefineProperties drops
         the app's global /p:CodesignProvision (the App Store publish passes the *app* profile) when
         building this reference, so the .appex resolves its OWN App Store profile from its csproj
         instead of being signed with the app profile (App-ID mismatch -> codesign failure). -->
    <ProjectReference Include="..\Connect.Ios.Extension\VpnHood.App.Connect.Ios.Extension.csproj">
      <IsAppExtension>true</IsAppExtension>
      <UndefineProperties>CodesignProvision</UndefineProperties>
    </ProjectReference>
  </ItemGroup>

  <!-- Self-clearing reminder for the ValidateXcodeVersion override (mirrors the SDK's _ValidateXcodeVersion). -->
  <Target Name="_VpnHoodWarnXcodeOverrideStale"
          AfterTargets="_DetectSdkLocations"
          Condition="'$(ValidateXcodeVersion)' == 'false' And '$(_CanOutputAppBundle)' == 'true' And '$(IsMacEnabled)' == 'true' And '$(_XcodeVersion)' != '' And '$(_RecommendedXcodeVersion)' != ''">
    <PropertyGroup>
      <_VpnHoodXcodeMM>$([System.Version]::Parse('$(_XcodeVersion)').Major).$([System.Version]::Parse('$(_XcodeVersion)').Minor)</_VpnHoodXcodeMM>
      <_VpnHoodRecXcodeMM>$([System.Version]::Parse('$(_RecommendedXcodeVersion)').Major).$([System.Version]::Parse('$(_RecommendedXcodeVersion)').Minor)</_VpnHoodRecXcodeMM>
    </PropertyGroup>
    <Message Condition="'$(VpnHoodXcodeCheckVerbose)' == 'true'" Importance="high"
             Text="[VpnHood] Xcode override check: installed=$(_XcodeVersion) ($(_VpnHoodXcodeMM)), workload-recommended=$(_RecommendedXcodeVersion) ($(_VpnHoodRecXcodeMM))" />
    <Warning Code="VPNHOOD0001"
             Condition="'$(_VpnHoodXcodeMM)' == '$(_VpnHoodRecXcodeMM)'"
             Text="The .NET for iOS workload now recommends Xcode $(_RecommendedXcodeVersion), which matches the installed Xcode $(_XcodeVersion). The ValidateXcodeVersion=false override in this project is no longer needed — remove it." />
  </Target>
</Project>
