<Project Sdk="Microsoft.NET.Sdk;Microsoft.NET.Sdk.Publish">
	<PropertyGroup>
		<Product>VpnHood! CLIENT</Product>
		<Description>VpnHood Linux Client App</Description>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<AssemblyName>VpnHoodClient</AssemblyName>
	</PropertyGroup>

	<PropertyGroup>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IncludeSymbols>True</IncludeSymbols>
		<SymbolPackageFormat>symbols.nupkg</SymbolPackageFormat>
		<LangVersion>latest</LangVersion>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)'=='Release'">
		<PublishTrimmed>False</PublishTrimmed>
		<RunAOTCompilation>False</RunAOTCompilation>
		<!--<PathMap>$(SolutionDir)=.</PathMap>-->
	</PropertyGroup>

	<PropertyGroup>
		<PackageLicenseExpression>LGPL-2.1-only</PackageLicenseExpression>
		<Company>OmegaHood LLC</Company>
		<Copyright>© OmegaHood LLC. All rights reserved.</Copyright>
		<PackageIcon>VpnHood.png</PackageIcon>
		<PackageProjectUrl>https://github.com/vpnhood/vpnhood</PackageProjectUrl>
		<RepositoryUrl>https://github.com/vpnhood/vpnhood</RepositoryUrl>
		<Version>8.0.824</Version>
		<FileVersion>$([System.DateTime]::Now.ToString("yyyy.M.d.HHmm"))</FileVersion>
		<AssemblyVersion></AssemblyVersion>
	</PropertyGroup>

	<!-- Optional private app settings (from the external ".user" folder) embedded as resources.
	     Conditional so a fork without them still builds; AppConfigs reads them at startup. -->
	<ItemGroup>
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\web\appsettings_web.json"
			LogicalName="AppSettings.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\web\appsettings_web.json')" />
		<EmbeddedResource Include="$(SolutionDir)\..\.user\VpnHoodClient\web\appsettings_web.$(Configuration).json"
			LogicalName="AppSettings_Environment.json"
			Condition="Exists('$(SolutionDir)\..\.user\VpnHoodClient\web\appsettings_web.$(Configuration).json')" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\AppLib\VpnHood.AppLib.Linux.Common\VpnHood.AppLib.Linux.Common.csproj" />
		<ProjectReference Include="..\Client\VpnHood.App.Client.csproj" />
	</ItemGroup>

</Project>
