<Project Sdk="MSTest.Sdk/4.3.0">
	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<IsPackable>false</IsPackable>
		<UseVSTest>true</UseVSTest>
		<!--MSTest.Sdk injects the test packages implicitly; override its bundled versions via these properties, NOT
		    PackageReference Update (which is a no-op against the SDK's late .targets Include). MSTestVersion defaults to
		    the SDK's bundled version, so only the VSTest platform needs pinning to the latest.-->
		<MicrosoftNETTestSdkVersion>18.7.0</MicrosoftNETTestSdkVersion>
	</PropertyGroup>

	<PropertyGroup>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<IncludeSymbols>True</IncludeSymbols>
		<SymbolPackageFormat>symbols.nupkg</SymbolPackageFormat>
		<LangVersion>latest</LangVersion>
	</PropertyGroup>

	<PropertyGroup>
		<PackageLicenseExpression>LGPL-2.1-only</PackageLicenseExpression>
		<Company>OmegaHood LLC</Company>
		<Copyright>© OmegaHood LLC. All rights reserved.</Copyright>
		<PackageProjectUrl>https://github.com/vpnhood/vpnhood</PackageProjectUrl>
		<RepositoryUrl>https://github.com/vpnhood/vpnhood</RepositoryUrl>
		<FileVersion>$([System.DateTime]::Now.ToString("yyyy.M.d.HHmm"))</FileVersion>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\src\AppLib\VpnHood.AppLib.App\VpnHood.AppLib.App.csproj" />
		<ProjectReference Include="..\..\src\Core\VpnHood.Core.IpLocations.SqliteProvider\VpnHood.Core.IpLocations.SqliteProvider.csproj" />
		<ProjectReference Include="..\VpnHood.Test\VpnHood.Test.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="VpnHood.AppLib.Assets.Ip2LocationLite" Version="7.0.740" />
		<PackageReference Include="VpnHood.Core.Proxies" Version="8.0.835" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Update="MSTest.TestAdapter" Version="4.3.0" />
	</ItemGroup>

	<ItemGroup>
	  <PackageReference Update="MSTest.TestFramework" Version="4.3.0" />
	</ItemGroup>

</Project>